# Core
PUBLIC_BASE_URL=http://localhost:8080
LISTEN_ADDR=:8080
DATABASE_URL=postgres://irl:irl@db:5432/irl?sslmode=disable

# Session signing (>=32 chars; openssl rand -hex 32). Insecure default refused
# at boot unless ALLOW_INSECURE_JWT_SECRET=true (local dev only).
JWT_SECRET=change-me-please-use-32-chars-minimum
# ALLOW_INSECURE_JWT_SECRET=true

# Auth. Three deployment profiles:
#   prod  — AUTH_MODE=oidc, Google issuer, OIDC_GOOGLE_WORKSPACE_DOMAINS=id5.io
#           (sign-in restricted to id5.io Workspace accounts via the `hd` claim).
#   stage — AUTH_MODE=oidc against Keycloak, OIDC_GOOGLE_WORKSPACE_DOMAINS empty
#           (no domain restriction — any Keycloak user is allowed).
#   local — AUTH_MODE=password (dev stub, no real credential check).
# Names come from the `profile` scope (given_name/family_name) on first login and
# are then editable by the user; OIDC_SCOPES defaults to "openid email profile".
AUTH_MODE=oidc
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=                       # defaults to PUBLIC_BASE_URL + /api/auth/oidc/callback
OIDC_SCOPES=openid email profile         # `profile` supplies given_name/family_name
OIDC_GOOGLE_WORKSPACE_DOMAINS=id5.io     # leave empty (e.g. stage/Keycloak) to allow all users

# People team. The FIRST user to sign in becomes admin automatically; admins
# then promote/demote others in-app — no admin allowlist env needed.
PEOPLE_TEAM_EMAIL=irl@id5.io

# SMTP (invitations, reminders + admin notifications). Empty SMTP_HOST disables
# email. Defaults target a plain, unauthenticated LAN relay (port 25, no TLS), so
# no username/password are needed. SMTP_FROM may be a bare address or a
# display-name form ("Name" <addr@host>).
# For an authenticating relay (e.g. Fastmail), use SMTP_HOST=smtp.fastmail.com,
# SMTP_PORT=465, SMTP_IMPLICIT_TLS=true, and set SMTP_USERNAME + SMTP_PASSWORD.
#
# AWS SES (production) — the sender speaks plain SMTP, so SES needs no code change,
# only this config. Use the SES *SMTP* credentials (generate them in the SES
# console; they are NOT your AWS access keys), point SMTP_HOST at the regional SES
# SMTP endpoint, and verify the SMTP_FROM identity/domain in SES (and leave the
# sandbox to send to arbitrary recipients):
#   SMTP_HOST=email-smtp.eu-central-1.amazonaws.com   # your SES region
#   SMTP_PORT=587
#   SMTP_USE_TLS=true        # STARTTLS; or SMTP_PORT=465 + SMTP_IMPLICIT_TLS=true
#   SMTP_USERNAME=<SES SMTP username>
#   SMTP_PASSWORD=<SES SMTP password>
#   SMTP_FROM=ID5 IRL <noreply@id5.io>                # must be a verified SES identity
SMTP_HOST=192.168.178.52
SMTP_PORT=25
SMTP_IMPLICIT_TLS=false
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=toldyouso robot <robot@junta-online.net>

# Slack messaging channel (optional). When set, the Messaging tab can send
# invitations and follow-ups as Slack DMs in addition to email. Uses a workspace
# BOT token (xoxb-…): an admin installs the app once and the bot can DM any
# employee — recipients never authorize the app themselves. The bot needs the
# scopes `users:read.email` (resolve company email → Slack user) and `chat:write`
# (send the DM). Leave empty to disable Slack.
SLACK_BOT_TOKEN=

# Reminder + digest scheduler
REMINDERS_ENABLED=true
REMINDER_TICK_INTERVAL=1h
# Default IANA timezone pre-filled when an admin creates a new event.
DEFAULT_EVENT_TIMEZONE=Europe/Paris

# CORS (defaults derived from PUBLIC_BASE_URL)
# CORS_ALLOWED_ORIGINS=
# METRICS_TOKEN=

# MCP server (Phase 7). Both set → /mcp + OAuth 2.1 enabled; both empty → /mcp off.
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=
# MCP_OAUTH_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
